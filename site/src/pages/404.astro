---
import Base from '../layouts/Base.astro';
---

<Base title="页面不存在 · 404">
  <div class="not-found">
    <h1>404</h1>
    <p class="not-found-msg">页面不存在 · Page not found</p>
    <a href="/" class="not-found-home">← 返回首页 · Back to home</a>
  </div>
</Base>

<style>
  .not-found {
    padding: 4rem 0;
    text-align: center;
  }

  .not-found h1 {
    font-size: 5rem;
    color: var(--border);
    margin: 0 0 0.5rem;
    line-height: 1;
  }

  .not-found-msg {
    color: var(--muted);
    font-size: 1.1rem;
    margin: 0 0 2rem;
  }

  .not-found-home {
    font-size: 0.95rem;
  }
</style>
